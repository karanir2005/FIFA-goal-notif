# Copy to .env (for local runs) and fill in. Do NOT commit your real .env.
# On the cloud host, set these as the platform's environment variables/secrets.

# Your private ntfy topic. Make it long and unguessable.
NTFY_TOPIC=rushil-wc-goals-CHANGEME

# ntfy server (leave default unless self-hosting).
NTFY_SERVER=https://ntfy.sh

# ESPN league slug. eng.1 for testing; fifa.world for the World Cup.
ESPN_LEAGUE=eng.1

# How often to poll, in seconds.
POLL_SECONDS=3
